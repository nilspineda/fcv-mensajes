# =====================================================
# VARIABLES DE ENTORNO - GOOGLE SHEETS IMPORT
# =====================================================

# ID del spreadsheet (lo encuentras en la URL de Google Sheets)
# Ejemplo: https://docs.google.com/spreadsheets/d/ABC123XYZ.../edit
GOOGLE_SHEET_ID=tu_sheet_id_aqui

# Rango de la hoja (opcional, por defecto es Hoja1!A:Z)
GOOGLE_SHEET_RANGE=Hoja1!A:Z

# Credenciales de Google Cloud Service Account (JSON completo)
# Copia todo el contenido del archivo .json de tu service account
GOOGLE_CREDENTIALS='{
  "type": "service_account",
  "project_id": "tu-proyecto",
  "private_key_id": "...",
  "private_key": "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",
  "client_email": "tu-cuenta@tu-proecto.iam.gserviceaccount.com",
  "client_id": "...",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token"
}'

# Supabase - Reemplaza con tus credenciales
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu_anon_key_aqui